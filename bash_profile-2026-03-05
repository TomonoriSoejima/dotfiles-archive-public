# requires env variables (ELASTIC_ECE_KEY, ELASTIC_ECE_GOV_KEY)
# takes a string ES API URI, ex ("_cluster/health", "/")

ELASTIC_ECE_KEY=████████████████████="

function ess {
  authX="Authorization: APIKey ${ELASTIC_ECE_KEY}"
  BASE="https://adminconsole.found.no"
  ## https://github.com/elastic/support-tech-lead/issues/1479
  # FLEET_OVERRIDE="x-elastic-product-origin:fleet"
  FLEET_OVERRIDE="asdf:asdf"
  ##
  MGMNT="X-Management-Request: true"
  PREREQ='👻 1st cache ID via "echo DEPLOYMENT_ID > .d" or "echo PROJECT_ID > .p"'
  

  # load directory variable caches: .d, .esRefId, .p, .gov
  ID=
  REF_ID=
  IS_ECH=
  IS_GOV=False
  # 2025Sep16 13% "Serverless" cases have Deployment IDs so if both(.d, .p) default believe .d 
  if [[ -f './.d' ]]; then 
    IS_ECH=true
    ID=$(cat "./.d") 
    # cannot be both(.gov, .p) so default believe .gov
    if [[ -f './.gov' ]]; then 
      IS_GOV=true
      BASE="https://admin.us-gov-east-1.aws.elastic-cloud.com"
      authX="Authorization: APIKey ${ELASTIC_ECE_GOV_KEY}"
    fi
  else
    # (.d, .p) not stored as ".id" because overlapping values for .esRefId with different interpretations
    if [[ -f './.p' ]]; then ID=$(cat "./.p") && IS_ECH=false; fi
  fi
  
  if [[ -f './.esRefId' ]]; then 
    if [[ ( -f './.d' || -f './.p' ) ]]; then
      REF_ID=$(cat "./.esRefId")
    else
      rm './.esRefId'
      echo $PREREQ
      return
    fi
  fi
  if [[ ! $ID ]]; then echo $PREREQ && return; fi

  # determine .esRefId if not previously cached, per (.d, .p)
  if [[ ! -f './.esRefId' ]]; then
    REF_ID=
    if [[ "$IS_ECH" == true ]]; then
      # only works for .d not .p
      tmp_domain="$BASE/api/v1/all/_search?q=$ID"
      tmp_response=$(eval curl --compressed -s -XGET -H \"$authX\" -H \"$MGMNT\" -H \"$FLEET_OVERRIDE\" \"$tmp_domain\")
      # optA=$( echo $tmp_response | jq -r ".results?|.[]|.info.resources.elasticsearch[].ref_id" | head -1 | sed 's/\"//g' )
      REF_ID=$( echo $tmp_response | jq -rc ".results?|.[]|.info.resources.elasticsearch[].ref_id"  )
      # known values (main-elasticsearch, elasticsearch, es-ref-id) but dynamic
    else
      # known values (elasticsearch, observability, security) and static
      tmp_domain="$BASE/api/v1/admin/serverless/projects"
      tmp_response=$(for PROJECT_TYPE in elasticsearch observability security; do (eval curl --compressed -s -f -XGET "$tmp_domain/${PROJECT_TYPE}/$ID" -H \"$authX\" || true); done)
      REF_ID=$( echo $tmp_response |  jq -rc '.type' )
    fi
    echo $REF_ID > "./.esRefId"
  fi

  if [[ $IS_ECH == true ]]; then
    DOMAIN="$BASE/api/v1/deployments/$ID/elasticsearch/$REF_ID/proxy"
  else
    DOMAIN="$BASE/api/v1/admin/serverless/projects/$REF_ID/$ID/_proxy"
  fi

  # .d api console API not allow no/extra '/' but .p not care
  if [[ -z "$1" ]]; then URI="/"; else URI=$1; fi
  if [[ ${URI:0:1} != "/" ]]; then URI="/$URI"; fi

  if [[ "$2" == "curl" ]]; then 
    echo "curl -s --compressed -XGET -H \"$authX\" -H \"$MGMNT\" -H \"$FLEET_OVERRIDE\" \"$DOMAIN$URI\""
  else
    echo $(eval "curl -s --compressed -XGET -H \"$authX\" -H \"$MGMNT\" -H \"$FLEET_OVERRIDE\" \"$DOMAIN$URI\"")  
  fi
}


alias mandiag="cat ~/code/dotfiles/bash/functions_elastic_diag | grep "

function diag {

    r=$(ess '/')
    if [[ $r == *"👻"* ]]; then echo $r && return; fi
    echo $r | jq . > version.json
    v=$(version $(cat version.json | jq -cr '.version.number') )
    if [[ $v == 0 ]]; then echo "👻 could not determine version" && return; fi # when ess not initialized
    echo "👀 v$(cat version.json | jq -r '.version.number') $(cat version.json | jq '.cluster_name')"
    if [[ $v < 070700 ]]; then echo "👻 YMMV v≤7.7"; fi

    run_all=false
    just_use=true
    read -p "🙋‍♀️ only USE? [y,n] " shortA
    case $shortA in
        n|N) run_all=true
    esac
    if [ "$run_all" = false ]; then 
        read -p "🙋‍♀️ only USE core? [y,n] " shortB 
        case $shortB in
            n|N) just_use=false
        esac
    fi
    
    # https://github.com/elastic/support-diagnostics/blob/main/src/main/resources/elastic-rest.yml
    echo " "
    echo "🦖"
    if [[ ! -d "cat" ]]; then mkdir "cat"; fi
    if [[ ! -d "commercial" ]]; then mkdir "commercial"; fi

    # https://medium.com/@stefnestor/use-method-for-elasticsearch-d976802d8ba6 
    echo "= performance: USE method"
    echo "    - master_node.json" && ess '_nodes/_master/_none' | jq . > master_node.json
    echo "    - cat_nodes.txt" && ess '_cat/nodes?v&s=master,name&h=name,id,master,node.role,cpu,heap.percent,disk.*,sstc,uptime,version' > ./cat/cat_nodes.txt
    echo "    - cat_allocation.txt" && ess '_cat/allocation?v' > ./cat/cat_allocation.txt
    echo "    - cluster_pending_tasks.json" && ess '_cluster/pending_tasks?human' | jq . > cluster_pending_tasks.json
