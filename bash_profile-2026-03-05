# Function to execute docker exec into a container with bash
dockbash() {
    if [ -z "$1" ]; then
        echo "Usage: dockbash <container_name>"
        return 1
    fi
    docker exec -it "$1" bash
}


title() {
  if [ -z "$1" ]; then
    printf "\033]0;%s\007" "$(pwd)"
  else
    printf "\033]0;%s\007" "$1"
  fi
}


# List all Terminal tabs
tabs() {
osascript -e '
tell application "Terminal"
    set window_list to every window
    set output to ""
    set counter to 1
    repeat with w in window_list
        set tab_list to every tab of w
        repeat with t in tab_list
            try
                set output to output & "[" & counter & "] " & (custom title of t) & linefeed
            on error
                set output to output & "[" & counter & "] [no title]" & linefeed
            end try
            set counter to counter + 1
        end repeat
    end repeat
    return output
end tell
'
}


jump_tab() {
  local output
  output=$(osascript -e '
  tell application "Terminal"
      set window_list to every window
      set output to ""
      set counter to 1
      repeat with w in window_list
          set tab_list to every tab of w
          repeat with t in tab_list
              try
                  set output to output & counter & ": " & (custom title of t) & linefeed
              on error
                  set output to output & counter & ": [no title]" & linefeed
              end try
              set counter to counter + 1
          end repeat
      end repeat
      return output
  end tell
  ')
  
  echo "$output"
  
  echo -n "Enter tab number to jump to: "
  read tab_num

  osascript -e "
  tell application \"Terminal\"
      set window_list to every window
      set counter to 1
      repeat with w in window_list
          set tab_list to every tab of w
          repeat with t in tab_list
              if counter = $tab_num then
                  set selected tab of w to t
                  set frontmost of w to true
                  activate
                  return
              end if
              set counter to counter + 1
          end repeat
      end repeat
  end tell
  "
}


