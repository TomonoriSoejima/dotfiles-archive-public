function diagme {
    if [[ -f ".d" || -f ".p" ]]; then 
        directory=${PWD##*/}
        directory=${directory:-/}
        id=
        if [[ -f ".p" ]]; then id=$(cat .p); fi
        if [[ -f ".d" ]]; then id=$(cat .d); fi
        ## keeping synced to lib/elastic 'file_name ='
        time=$(date -u "+%Y%m%dT%H%M") # "+%Y%b%dT%H%M"
        mkcd "${time}-${directory}-${id:0:6}-es"
        # mkcd "${time}-${dep:0:6}-es"
        ##
        if [[ -a "../.p" ]]; then cp ../.p .p; fi
        if [[ -a "../.d" ]]; then cp ../.d .d; fi
        if [[ -a "../.gov" ]]; then cp ../.gov .gov ; fi
        diag
    else
        echo "👻 cache .d or .p first"
    fi
}

